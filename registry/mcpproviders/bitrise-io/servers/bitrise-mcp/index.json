{
  "name": "Bitrise MCP Server",
  "description": "MCP Server for the Bitrise API, enabling app management, build operations, artifact management and more.",
  "mcpversion": "1.0",
  "serverversion": "1.0",
  "repository": {
    "url": "https://github.com/bitrise-io/bitrise-mcp",
    "name": "bitrise-io/bitrise-mcp"
  },
  "deployment": {
    "sandbox": {
      "runtime": "uv",
      "package": "bitrise-mcp",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/bitrise-io/bitrise-mcp@v1.1.0",
        "bitrise-mcp"
      ],
      "env": [
        {
          "name": "BITRISE_TOKEN",
          "description": "Bitrise API token for authentication",
          "required": true
        }
      ]
    }
  }
}