{
  "name": "agentrpc",
  "description": "Universal RPC layer for AI agents across network boundaries and languages, supporting Model Context Protocol (MCP) and OpenAI-compatible tool definitions.",
  "mcpversion": "unknown",
  "serverversion": "unknown",
  "repository": {
    "url": "https://github.com/agentrpc/agentrpc",
    "name": "agentrpc/agentrpc"
  },
  "tools": [],
  "resources": [],
  "endpoints": {
    "stdio": {
      "deployment": "sandbox"
    }
  },
  "deployment": {
    "sandbox": {
      "runtime": "node",
      "package": "agentrpc",
      "command": "mcp",
      "args": [
        "-y",
        "agentrpc",
        "mcp"
      ],
      "env": [
        {
          "name": "AGENTRPC_API_SECRET",
          "description": "API secret for authentication",
          "required": true
        }
      ]
    }
  }
}