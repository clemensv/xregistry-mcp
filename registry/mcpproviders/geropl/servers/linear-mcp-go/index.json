{
  "name": "Linear MCP Server",
  "description": "A Model Context Protocol (MCP) server for Linear, written in Go. This server provides tools for interacting with the Linear API through the MCP protocol.",
  "mcpversion": "1.0",
  "serverversion": "unknown",
  "repository": {
    "url": "https://github.com/geropl/linear-mcp-go",
    "name": "geropl/linear-mcp-go"
  },
  "tools": [
    {
      "name": "linear_create_issue",
      "description": "Creates a new Linear issue with specified details. Supports creating sub-issues and assigning labels.",
      "inputschema": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "team": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "priority": {
            "type": "integer"
          },
          "status": {
            "type": "string"
          },
          "parentIssue": {
            "type": "string"
          },
          "labels": {
            "type": "string"
          }
        },
        "required": [
          "title",
          "team"
        ]
      }
    },
    {
      "name": "linear_update_issue",
      "description": "Updates an existing Linear issue's properties.",
      "inputschema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "priority": {
            "type": "integer"
          }
        },
        "required": [
          "id"
        ]
      }
    }
  ],
  "endpoints": {
    "stdio": {
      "deployment": "sandbox"
    }
  },
  "deployment": {
    "sandbox": {
      "runtime": "go",
      "package": "linear-mcp-go",
      "command": "./linear-mcp-go",
      "args": [
        "serve"
      ],
      "env": [
        {
          "name": "LINEAR_API_KEY",
          "description": "Linear API key environment variable",
          "required": true
        }
      ]
    }
  }
}