{
  "name": "BlenderMCP",
  "description": "BlenderMCP connects Blender to Claude AI through the Model Context Protocol (MCP), allowing Claude to directly interact with and control Blender. This integration enables prompt assisted 3D modeling, scene creation, and manipulation.",
  "mcpversion": "unspecified",
  "serverversion": "1.1.0",
  "repository": {
    "url": "https://github.com/ahujasid/blender-mcp",
    "name": "ahujasid/blender-mcp",
    "subfolder": "src/blender_mcp",
    "branch": "main"
  },
  "docs": "https://www.youtube.com/watch?v=lCyQ717DuzQ",
  "tools": [],
  "resources": [],
  "endpoints": {
    "stdio": {
      "deployment": "sandbox"
    }
  },
  "deployment": {
    "sandbox": {
      "runtime": "uv",
      "package": "blender-mcp",
      "command": "uvx",
      "args": [
        "blender-mcp"
      ],
      "env": []
    }
  }
}