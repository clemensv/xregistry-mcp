{
  "name": "solana-actions",
  "description": "An MCP server exposing Solana Agent Kit actions as MCP tools, enabling onchain interaction via Model Context Protocol.",
  "mcpversion": "1.0.0",
  "serverversion": "1.0.0",
  "documentation": "https://docs.sendai.fun/v0/introduction",
  "repository": {
    "url": "https://github.com/sendaifun/solana-agent-kit",
    "name": "sendaifun/solana-agent-kit"
  },
  "tools": [],
  "prompts": [],
  "resources": [],
  "endpoints": {
    "stdio": {
      "deployment": "sandbox"
    }
  },
  "deployment": {
    "sandbox": {
      "runtime": "node",
      "package": "solana-agent-kit",
      "command": "node",
      "args": [],
      "env": [
        {
          "name": "GROQ_API_KEY",
          "description": "API key for Groq model access",
          "required": false
        },
        {
          "name": "OPENAI_API_KEY",
          "description": "API key for OpenAI access",
          "required": false
        },
        {
          "name": "SOLANA_PRIVATE_KEY",
          "description": "Private key for Solana wallet",
          "required": true
        },
        {
          "name": "RPC_URL",
          "description": "RPC URL for Solana network",
          "required": true
        }
      ]
    }
  }
}