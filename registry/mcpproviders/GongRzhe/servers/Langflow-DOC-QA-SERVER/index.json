{
  "name": "doc-qa-server",
  "description": "A Model Context Protocol server for document Q&A powered by Langflow",
  "mcpversion": "1.0",
  "serverversion": "0.1.0",
  "repository": {
    "url": "https://github.com/GongRzhe/Langflow-DOC-QA-SERVER",
    "name": "GongRzhe/Langflow-DOC-QA-SERVER"
  },
  "tools": [
    {
      "name": "query_docs",
      "description": "Query the document Q&A system with a prompt",
      "inputschema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "The query prompt to search for in the documents"
          }
        },
        "required": [
          "query"
        ]
      }
    }
  ],
  "endpoints": {
    "stdio": {
      "deployment": "sandbox"
    }
  },
  "deployment": {
    "sandbox": {
      "runtime": "node",
      "package": "@GongRzhe/Langflow-DOC-QA-SERVER",
      "command": "node",
      "args": [
        "/path/to/doc-qa-server/build/index.js"
      ],
      "env": [
        {
          "name": "API_ENDPOINT",
          "description": "The endpoint URL for the Langflow API service.",
          "required": false,
          "default": "http://127.0.0.1:7860/api/v1/run/480ec7b3-29d2-4caa-b03b-e74118f35fac"
        }
      ]
    }
  }
}