{
  "name": "bing-search",
  "description": "A Model Context Protocol (MCP) server for Microsoft Bing Search API integration, allowing AI assistants to perform web, news, and image searches.",
  "mcpversion": "1.0",
  "serverversion": "1.0",
  "tools": [
    {
      "name": "bing_web_search",
      "description": "General web search for information, websites, and content.",
      "inputschema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Search query"
          },
          "count": {
            "type": "integer",
            "description": "Number of results (1-50)"
          },
          "offset": {
            "type": "integer",
            "description": "Pagination offset"
          },
          "market": {
            "type": "string",
            "description": "Market code like en-US, en-GB"
          }
        },
        "required": [
          "query",
          "count",
          "offset",
          "market"
        ]
      }
    },
    {
      "name": "bing_news_search",
      "description": "Search for news articles and current events.",
      "inputschema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "News search query"
          },
          "count": {
            "type": "integer",
            "description": "Number of results (1-50)"
          },
          "market": {
            "type": "string",
            "description": "Market code like en-US, en-GB"
          },
          "freshness": {
            "type": "string",
            "description": "Time period of news (Day, Week, Month)"
          }
        },
        "required": [
          "query",
          "count",
          "market",
          "freshness"
        ]
      }
    },
    {
      "name": "bing_image_search",
      "description": "Search for images.",
      "inputschema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Image search query"
          },
          "count": {
            "type": "integer",
            "description": "Number of results (1-50)"
          },
          "market": {
            "type": "string",
            "description": "Market code like en-US, en-GB"
          }
        },
        "required": [
          "query",
          "count",
          "market"
        ]
      }
    }
  ],
  "deployment": {
    "sandbox": {
      "runtime": "python",
      "package": "bing-search-mcp",
      "command": "uvx",
      "args": [
        "bing-search-mcp"
      ],
      "env": [
        {
          "name": "BING_API_KEY",
          "description": "Microsoft Bing Search API key",
          "required": true
        }
      ]
    }
  },
  "repository": {
    "url": "https://github.com/leehanchung/bing-search-mcp",
    "name": "leehanchung/bing-search-mcp"
  }
}