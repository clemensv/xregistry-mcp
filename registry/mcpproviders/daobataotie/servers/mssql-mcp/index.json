{
  "name": "mssql-manager",
  "description": "MSSQL MCP Server provides database interaction and business intelligence capabilities, enabling running SQL queries, analyzing business data, and automatically generating business insight memos.",
  "mcpversion": "0.1.0",
  "serverversion": "0.1.0",
  "tools": [
    {
      "name": "read_query",
      "description": "\u5728 MSSQL \u6570\u636e\u5e93\u4e0a\u6267\u884c SELECT \u67e5\u8be2",
      "inputschema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "\u8981\u6267\u884c\u7684 SELECT SQL \u67e5\u8be2"
          }
        },
        "required": [
          "query"
        ]
      }
    },
    {
      "name": "write_query",
      "description": "\u5728 MSSQL \u6570\u636e\u5e93\u4e0a\u6267\u884c INSERT\u3001UPDATE \u6216 DELETE \u67e5\u8be2",
      "inputschema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "\u8981\u6267\u884c\u7684 SQL \u67e5\u8be2"
          }
        },
        "required": [
          "query"
        ]
      }
    },
    {
      "name": "create_table",
      "description": "\u5728 MSSQL \u6570\u636e\u5e93\u4e2d\u521b\u5efa\u65b0\u8868",
      "inputschema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "CREATE TABLE SQL \u8bed\u53e5"
          }
        },
        "required": [
          "query"
        ]
      }
    },
    {
      "name": "list_tables",
      "description": "\u5217\u51fa MSSQL \u6570\u636e\u5e93\u4e2d\u7684\u6240\u6709\u8868",
      "inputschema": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "describe_table",
      "description": "\u83b7\u53d6\u7279\u5b9a\u8868\u7684\u67b6\u6784\u4fe1\u606f",
      "inputschema": {
        "type": "object",
        "properties": {
          "table_name": {
            "type": "string",
            "description": "\u8981\u63cf\u8ff0\u7684\u8868\u540d"
          }
        },
        "required": [
          "table_name"
        ]
      }
    },
    {
      "name": "append_insight",
      "description": "\u5411\u5907\u5fd8\u5f55\u6dfb\u52a0\u4e1a\u52a1\u6d1e\u5bdf",
      "inputschema": {
        "type": "object",
        "properties": {
          "insight": {
            "type": "string",
            "description": "\u4ece\u6570\u636e\u5206\u6790\u4e2d\u53d1\u73b0\u7684\u4e1a\u52a1\u6d1e\u5bdf"
          }
        },
        "required": [
          "insight"
        ]
      }
    }
  ],
  "resources": [
    {
      "name": "\u4e1a\u52a1\u6d1e\u5bdf\u5907\u5fd8\u5f55",
      "description": "\u4e00\u4e2a\u5b9e\u65f6\u66f4\u65b0\u7684\u4e1a\u52a1\u6d1e\u5bdf\u6587\u6863",
      "mimetype": "text/plain",
      "uritemplate": "memo://insights"
    }
  ],
  "prompts": [
    {
      "name": "mcp-demo",
      "description": "\u4e00\u4e2a\u7528\u4e8e\u5728 MSSQL \u6570\u636e\u5e93\u4e2d\u521b\u5efa\u521d\u59cb\u6570\u636e\u5e76\u6f14\u793a MSSQL MCP \u670d\u52a1\u5668\u529f\u80fd\u7684\u63d0\u793a",
      "arguments": [
        {
          "name": "topic",
          "description": "\u7528\u4e8e\u751f\u6210\u521d\u59cb\u6570\u636e\u7684\u4e3b\u9898",
          "required": true
        }
      ]
    }
  ],
  "deployment": {
    "sandbox": {
      "runtime": "python",
      "package": "mcp",
      "command": "python",
      "args": [
        "src/server.py"
      ],
      "env": []
    }
  },
  "endpoints": {
    "stdio": {
      "deployment": "sandbox"
    }
  },
  "repository": {
    "url": "https://github.com/daobataotie/mssql-mcp",
    "name": "daobataotie/mssql-mcp"
  }
}