{
  "name": "mcp-local-rag",
  "description": "\"primitive\" RAG-like web search model context protocol (MCP) server that runs locally. \u2728 no APIs \u2728",
  "mcpversion": "1.0",
  "serverversion": "unknown",
  "repository": {
    "url": "https://github.com/nkapila6/mcp-local-rag",
    "name": "nkapila6/mcp-local-rag"
  },
  "tools": [
    {
      "name": "rag_search",
      "description": "Search the web for a given query. Give back context to the LLM with a RAG-like similarity sort.",
      "inputschema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "The query to search for."
          },
          "num_results": {
            "type": "integer",
            "description": "Number of results to return."
          },
          "top_k": {
            "type": "integer",
            "description": "Use top \"k\" results for content."
          }
        },
        "required": [
          "query"
        ]
      }
    }
  ],
  "deployment": {
    "sandbox": {
      "runtime": "uv",
      "package": "mcp-local-rag",
      "command": "uvx",
      "args": [
        "--python=3.10",
        "--from",
        "git+https://github.com/nkapila6/mcp-local-rag",
        "mcp-local-rag"
      ]
    }
  }
}