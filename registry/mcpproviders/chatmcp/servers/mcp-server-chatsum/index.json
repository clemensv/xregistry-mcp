{
  "name": "mcp-server-chatsum",
  "description": "This MCP Server is used to summarize your chat messages.",
  "mcpversion": "1.0",
  "serverversion": "0.1.0",
  "tools": [
    {
      "name": "query_chat_messages",
      "description": "Query chat messages with given parameters and summarize chat messages based on the query prompt.",
      "inputschema": {
        "type": "object"
      }
    }
  ],
  "resources": [],
  "endpoints": {
    "stdio": {
      "deployment": "sandbox"
    }
  },
  "deployment": {
    "sandbox": {
      "runtime": "node",
      "package": "@modelcontextprotocol/sdk",
      "command": "node",
      "args": [
        "build/index.js"
      ],
      "env": [
        {
          "name": "CHAT_DB_PATH"
        }
      ]
    }
  },
  "repository": {
    "url": "https://github.com/chatmcp/mcp-server-chatsum",
    "name": "chatmcp/mcp-server-chatsum"
  }
}