{
  "name": "MCP Server",
  "description": "A CLI tool to quickly get started building your very own MCP (Model Context Protocol) server using FastMCP",
  "mcpversion": "1.0.0",
  "serverversion": "1.0.0",
  "tools": [
    {
      "name": "hello_world",
      "description": "A simple hello world tool",
      "inputschema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name to greet"
          }
        },
        "required": [
          "name"
        ]
      }
    },
    {
      "name": "goodbye",
      "description": "A simple goodbye tool",
      "inputschema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name to bid farewell to"
          }
        },
        "required": [
          "name"
        ]
      }
    }
  ],
  "resources": [
    {
      "uritemplate": "example://{id}",
      "name": "Example Resource",
      "description": "Resource ID",
      "mimetype": "text/plain"
    }
  ],
  "prompts": [
    {
      "name": "greeting",
      "description": "A simple greeting prompt",
      "arguments": [
        {
          "name": "name",
          "description": "Name to greet",
          "required": true
        }
      ]
    }
  ],
  "endpoints": {
    "stdio": {
      "deployment": "sandbox"
    },
    "http": {
      "uri": "http://localhost:3001/sse",
      "authorization": {
        "type": "none",
        "required": false
      }
    }
  },
  "deployment": {
    "sandbox": {
      "runtime": "bun",
      "package": "@mcpdotdirect/template-mcp-server",
      "command": "bun",
      "args": [
        "run",
        "src/index.ts"
      ],
      "env": []
    }
  },
  "repository": {
    "url": "https://github.com/mcpdotdirect/template-mcp-server",
    "name": "mcpdotdirect/template-mcp-server"
  }
}