{
  "name": "FastMCP",
  "description": "A TypeScript framework for building MCP servers capable of handling client sessions.",
  "mcpversion": "1.0.0",
  "serverversion": "1.0.0",
  "repository": {
    "url": "https://github.com/punkpeye/fastmcp",
    "name": "punkpeye/fastmcp"
  },
  "tools": [
    {
      "name": "add",
      "description": "Add two numbers",
      "inputschema": {
        "type": "object",
        "properties": {
          "a": {
            "type": "number"
          },
          "b": {
            "type": "number"
          }
        },
        "required": [
          "a",
          "b"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "fetch-zod",
      "description": "Fetch the content of a url (using Zod)",
      "inputschema": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          }
        },
        "required": [
          "url"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "fetch-arktype",
      "description": "Fetch the content of a url (using ArkType)",
      "inputschema": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          }
        },
        "required": [
          "url"
        ],
        "additionalProperties": false
      }
    }
  ],
  "resources": [
    {
      "name": "Application Logs",
      "mimetype": "text/plain",
      "uritemplate": "file:///logs/{name}.log"
    }
  ],
  "prompts": [
    {
      "name": "git-commit",
      "description": "Generate a Git commit message",
      "arguments": [
        {
          "name": "changes",
          "description": "Git diff or description of changes",
          "required": true
        }
      ]
    },
    {
      "name": "countryPoem",
      "description": "Writes a poem about a country",
      "arguments": [
        {
          "name": "name",
          "description": "Name of the country",
          "required": true
        }
      ]
    }
  ],
  "endpoints": {
    "stdio": {
      "deployment": "sandbox"
    },
    "http": {},
    "websockets": {},
    "mqtt": {},
    "httplocal": {}
  },
  "deployment": {
    "sandbox": {
      "runtime": "node",
      "package": "fastmcp",
      "command": "start"
    }
  }
}