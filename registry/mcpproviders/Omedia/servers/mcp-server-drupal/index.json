{
  "name": "mcp-server-drupal",
  "description": "A typescript based companion Model Context Protocol (MCP) server for the Drupal MCP module that works with the STDIO transport.",
  "mcpversion": "unspecified",
  "serverversion": "unspecified",
  "repository": {
    "url": "https://github.com/Omedia/mcp-server-drupal",
    "name": "Omedia/mcp-server-drupal"
  },
  "tools": [],
  "resources": [],
  "endpoints": {
    "stdio": {
      "deployment": "sandbox"
    }
  },
  "deployment": {
    "container": {
      "image": "ghcr.io/omedia/mcp-server-drupal",
      "args": [
        "--drupal-url=__DRUPAL_BASE_URL__"
      ],
      "env": []
    },
    "sandbox": {
      "runtime": "deno",
      "package": "jsr:@omedia/mcp-server-drupal",
      "command": "deno run -A jsr:@omedia/mcp-server-drupal@<VERSION>",
      "args": [
        "--drupal-url",
        "__DRUPAL_BASE_URL__"
      ],
      "env": []
    }
  }
}