{
  "name": "mcp-redis-cloud",
  "description": "Model Context Protocol (MCP) server for managing Redis Cloud resources via natural language commands.",
  "mcpversion": "unknown",
  "serverversion": "unknown",
  "tools": [],
  "resources": [],
  "endpoints": {
    "stdio": {
      "deployment": "sandbox"
    }
  },
  "deployment": {
    "sandbox": {
      "runtime": "node",
      "package": "@modelcontextprotocol/sdk",
      "command": "node",
      "args": [
        "--experimental-fetch",
        "<absolute_path_to_project_root>/dist/index.js"
      ],
      "env": [
        {
          "name": "API_KEY",
          "description": "Redis Cloud API key",
          "required": true
        },
        {
          "name": "SECRET_KEY",
          "description": "Redis Cloud API secret key",
          "required": true
        }
      ]
    }
  },
  "repository": {
    "url": "https://github.com/redis/mcp-redis-cloud",
    "name": "redis/mcp-redis-cloud"
  }
}