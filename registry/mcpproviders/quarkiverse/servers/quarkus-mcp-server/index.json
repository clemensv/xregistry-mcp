{
  "name": "Quarkus Model Context Protocol (MCP) Server",
  "description": "This extension provides declarative and programmatic APIs that enable developers to implement the MCP server features easily.",
  "documentation": "https://quarkiverse.github.io/quarkiverse-docs/quarkus-mcp-server/dev/index.html",
  "mcpversion": "unspecified",
  "serverversion": "unspecified",
  "tools": [
    {
      "name": "toLowerCase",
      "description": "Converts the string value to lower case"
    }
  ],
  "prompts": [
    {
      "name": "code_assist",
      "arguments": [
        {
          "name": "lang",
          "required": false
        }
      ]
    }
  ],
  "resources": [
    {
      "uritemplate": "file:///project/alpha",
      "name": "alpha"
    }
  ],
  "deployment": {},
  "repository": {
    "url": "https://github.com/quarkiverse/quarkus-mcp-server",
    "name": "quarkiverse/quarkus-mcp-server"
  },
  "endpoints": {
    "http": {
      "authorization": {
        "type": "unspecified",
        "required": false
      },
      "uri": "unspecified"
    }
  }
}