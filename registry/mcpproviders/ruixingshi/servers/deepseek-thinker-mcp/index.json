{
  "name": "deepseek-thinker",
  "description": "A MCP (Model Context Protocol) provider Deepseek reasoning content to MCP-enabled AI Clients, like Claude Desktop. Supports access to Deepseek's thought processes from the Deepseek API service or from a local Ollama server.",
  "mcpversion": "1.0.0",
  "serverversion": "1.0.0",
  "tools": [
    {
      "name": "get-deepseek-thinker",
      "description": "Perform reasoning using the Deepseek model",
      "inputschema": {
        "type": "object",
        "properties": {
          "originPrompt": {
            "type": "string",
            "description": "user's original prompt"
          }
        },
        "required": [
          "originPrompt"
        ]
      }
    }
  ],
  "endpoints": {
    "stdio": {
      "deployment": "sandbox"
    }
  },
  "deployment": {
    "sandbox": {
      "runtime": "node",
      "package": "deepseek-thinker-mcp",
      "command": "npx",
      "args": [
        "-y",
        "deepseek-thinker-mcp"
      ],
      "env": [
        {
          "name": "API_KEY",
          "description": "Your OpenAI API Key",
          "required": false
        },
        {
          "name": "BASE_URL",
          "description": "API Base URL",
          "required": false
        },
        {
          "name": "USE_OLLAMA",
          "description": "Set to true to use Ollama mode",
          "required": false
        }
      ]
    }
  },
  "repository": {
    "url": "https://github.com/ruixingshi/deepseek-thinker-mcp",
    "name": "ruixingshi/deepseek-thinker-mcp"
  }
}